{
  "name": "ai-website",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "vitest run",
    "model:action6": "node scripts/generate-action6-inspired-glb.mjs",
    "preview": "vite preview",
    "video:preview:echarts": "npx hyperframes preview videos/echarts-vibecoding-guide --port 3017",
    "video:render:echarts": "npx hyperframes render videos/echarts-vibecoding-guide --output videos/echarts-vibecoding-guide/renders/echarts-vibecoding-guide-voiceover.mp4 --quality standard --fps 30",
    "video:mux:echarts": "ffmpeg -y -i videos/echarts-vibecoding-guide/renders/echarts-vibecoding-guide-voiceover.mp4 -i videos/echarts-vibecoding-guide/renders/narration-yunxi-fit.m4a -map 0:v:0 -map 1:a:0 -c:v copy -c:a aac -b:a 160k -shortest videos/echarts-vibecoding-guide/renders/echarts-vibecoding-guide-voiceover.tmp.mp4 && mv videos/echarts-vibecoding-guide/renders/echarts-vibecoding-guide-voiceover.tmp.mp4 videos/echarts-vibecoding-guide/renders/echarts-vibecoding-guide-voiceover.mp4",
    "video:publish:echarts": "mkdir -p public/videos/echarts-vibecoding-guide && cp videos/echarts-vibecoding-guide/renders/echarts-vibecoding-guide-voiceover.mp4 public/videos/echarts-vibecoding-guide/echarts-vibecoding-guide-voiceover.mp4",
    "video:build:echarts": "npm run video:render:echarts && npm run video:mux:echarts && npm run video:publish:echarts"
  },
  "dependencies": {
    "echarts": "^6.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
